{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bubnov-alexander/portgolio-manager",
    "type": "project",
    "description": "Personal portfolio backend project built with Laravel, Apiato and Filament.",
    "keywords": [
        "portfolio",
        "laravel",
        "apiato",
        "filament",
        "php"
    ],
    "license": "MIT",
    "homepage": "https://github.com/bubnov-alexander/portgolio-manager",
    "support": {
        "issues": "https://github.com/bubnov-alexander/portgolio-manager/issues",
        "source": "https://github.com/bubnov-alexander/portgolio-manager"
    },
    "authors": [
        {
            "name": "Alexander Bubnov",
            "email": "kinoki445@gmail.com",
            "role": "Author"
        }
    ],
    "require": {
        "php": "^8.4",
        "apiato/core": "^13.1",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-settings-plugin": "^5.5",
        "laravel/passport": "^13.0",
        "laravel/telescope": "^5.20",
        "spatie/laravel-data": "^4.21",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-settings": "^3.7",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "require-dev": {
        "brianium/paratest": "^7.4",
        "fakerphp/faker": "^1.19.1",
        "friendsofphp/php-cs-fixer": "^3.0",
        "jetbrains/phpstorm-attributes": "^1.0",
        "larastan/larastan": "^3.0",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.0",
        "php-standard-library/psalm-plugin": "^2.3",
        "phpmd/phpmd": "@stable",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0.1",
        "psalm/plugin-laravel": "^3.0",
        "psalm/plugin-mockery": "^1.2",
        "psalm/plugin-phpunit": "^0.19.2",
        "roave/security-advisories": "dev-latest",
        "vimeo/psalm": "^6.0.0",
        "thecodingmachine/phpstan-safe-rule": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "ide-helper": [
            "@php artisan ide-helper:models --nowrite --reset",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta",
            "@php artisan ide-helper:eloquent"
        ],
        "fixer": [
            "php-cs-fixer fix"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "app/Ship/composer.json",
                "app/Containers/*/*/composer.json"
            ],
            "recurse": true,
            "replace": false,
            "merge-dev": true,
            "merge-extra": true,
            "merge-extra-deep": false,
            "merge-scripts": true
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "github-protocols": [
            "https"
        ],
        "allow-plugins": {
            "apiato/container-installer": true,
            "composer/package-versions-deprecated": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [{
        "name": "packagist",
        "type": "composer",
        "url": "https://repo.packagist.org"
    }]
}
